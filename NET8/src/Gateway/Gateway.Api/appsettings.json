{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "SuperSecretKey12345678901234567890123456789012",
    "Issuer": "MassiveLoadSystem",
    "Audience": "MassiveLoadClients"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "control-route": {
        "ClusterId": "control-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/carga/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/carga/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5101"
          }
        }
      },
      "control-cluster": {
        "Destinations": {
          "control-service": {
            "Address": "http://localhost:5102"
          }
        }
      }
    }
  }
}
